---
// HeroXV.astro - Sección principal Mis XV Años
// Diseño inspirado en plantilla: esfera, fresa, globoperrito, copa, marco
---

<section
    class="relative w-full overflow-hidden bg-[#fdf6f8] min-h-screen flex items-center justify-center"
    id="hero-xv"
>
    <!-- ====== DECORATIVOS ESQUINAS ====== -->

    <!-- Esfera - esquina superior izquierda -->
    <div
        class="absolute top-0 left-0 z-20 w-[45%] sm:w-[38%] md:w-[32%] lg:w-[28%]"
        id="deco-esfera"
    >
        <img
            src="/imagenes/esfera.png"
            alt="Esfera decorativa"
            class="w-full h-auto object-contain"
        />
    </div>

    <!-- Globo perrito - esquina superior derecha -->
    <div
        class="absolute top-0 right-0 z-20 w-[28%] sm:w-[24%] md:w-[20%] lg:w-[18%]"
        id="deco-globo"
    >
        <img
            src="/imagenes/globoperrito.png"
            alt="Globo perrito decorativo"
            class="w-full h-auto object-contain"
        />
    </div>

    <!-- Fresa - esquina inferior izquierda -->
    <div
        class="absolute bottom-0 left-0 z-20 w-[38%] sm:w-[30%] md:w-[26%] lg:w-[22%]"
        id="deco-fresa"
    >
        <img
            src="/imagenes/fresa.png"
            alt="Fresa decorativa"
            class="w-full h-auto object-contain"
        />
    </div>

    <!-- Copa - esquina inferior derecha -->
    <div
        class="absolute bottom-0 right-0 z-20 w-[30%] sm:w-[24%] md:w-[20%] lg:w-[18%]"
        id="deco-copa"
    >
        <img
            src="/imagenes/copa.png"
            alt="Copa decorativa"
            class="w-full h-auto object-contain"
        />
    </div>

    <!-- ====== MARCO INTERIOR ====== -->
    <div
        class="absolute inset-[6%] sm:inset-[7%] md:inset-[8%] z-10 pointer-events-none"
        id="marco"
    >
        <img
            src="/imagenes/marco.png"
            alt="Marco decorativo"
            class="w-full h-full object-fill"
        />
    </div>

    <!-- ====== CONTENIDO CENTRAL ====== -->
    <div
        class="relative z-30 flex flex-col items-center justify-center text-center px-8 py-16 w-full max-w-sm sm:max-w-md mx-auto"
        id="contenido-central"
    >
        <!-- NOMBRE -->
        <h1
            class="font-great-vibes text-[72px] sm:text-[88px] md:text-[100px] leading-none mb-2"
            style="
                color: #c4607a;
                text-shadow:
                    2px 2px 0px #a04060,
                    -1px -1px 0px rgba(255,255,255,0.3);
                font-family: 'Great Vibes', 'Dancing Script', cursive;
            "
            id="nombre-xv"
        >
            Mayra
        </h1>

        <!-- MIS 15 AÑOS con flores al centro -->
        <div
            class="relative flex items-center justify-center gap-1 mb-6"
            id="subtitulo-xv"
        >
            <!-- mis -->
            <span
                class="text-[#c9a84c] italic"
                style="font-family: 'Playfair Display', 'Georgia', serif; font-size: clamp(1.1rem, 4vw, 1.5rem); font-weight: 400;"
            >
                mis
            </span>

            <!-- 15 con flores debajo -->
            <div class="relative flex flex-col items-center mx-1">
                <span
                    class="text-[#e8a0b0] font-bold leading-none"
                    style="font-family: 'Playfair Display', serif; font-size: clamp(2.8rem, 10vw, 4rem); line-height: 1;"
                >
                    15
                </span>
                <!-- Flores pequeñas debajo del 15 -->
                <div class="-mt-1">
                    <svg
                        width="60"
                        height="28"
                        viewBox="0 0 60 28"
                        fill="none"
                        xmlns="http://www.w3.org/2000/svg"
                    >
                        <!-- Hojas verdes -->
                        <ellipse
                            cx="12"
                            cy="20"
                            rx="7"
                            ry="4"
                            fill="#6aab5e"
                            transform="rotate(-30 12 20)"
                            opacity="0.85"></ellipse>
                        <ellipse
                            cx="48"
                            cy="20"
                            rx="7"
                            ry="4"
                            fill="#6aab5e"
                            transform="rotate(30 48 20)"
                            opacity="0.85"></ellipse>
                        <ellipse
                            cx="6"
                            cy="16"
                            rx="5"
                            ry="3"
                            fill="#8bc34a"
                            transform="rotate(-50 6 16)"
                            opacity="0.7"></ellipse>
                        <ellipse
                            cx="54"
                            cy="16"
                            rx="5"
                            ry="3"
                            fill="#8bc34a"
                            transform="rotate(50 54 16)"
                            opacity="0.7"></ellipse>
                        <!-- Flores rosas -->
                        <circle cx="30" cy="10" r="5" fill="#f4a8bc"></circle>
                        <circle cx="30" cy="10" r="2.5" fill="#e88aa4"></circle>
                        <circle cx="20" cy="16" r="4" fill="#f4a8bc"></circle>
                        <circle cx="20" cy="16" r="2" fill="#e88aa4"></circle>
                        <circle cx="40" cy="16" r="4" fill="#f4a8bc"></circle>
                        <circle cx="40" cy="16" r="2" fill="#e88aa4"></circle>
                        <!-- Pétalos decorativos -->
                        <ellipse
                            cx="30"
                            cy="5"
                            rx="2"
                            ry="3"
                            fill="#f9c4d2"
                            opacity="0.8"></ellipse>
                        <ellipse
                            cx="30"
                            cy="15"
                            rx="2"
                            ry="3"
                            fill="#f9c4d2"
                            opacity="0.8"></ellipse>
                        <ellipse
                            cx="25"
                            cy="10"
                            rx="3"
                            ry="2"
                            fill="#f9c4d2"
                            opacity="0.8"></ellipse>
                        <ellipse
                            cx="35"
                            cy="10"
                            rx="3"
                            ry="2"
                            fill="#f9c4d2"
                            opacity="0.8"></ellipse>
                        <circle
                            cx="30"
                            cy="10"
                            r="1.5"
                            fill="#fff"
                            opacity="0.6"></circle>
                    </svg>
                </div>
            </div>

            <!-- años -->
            <span
                class="text-[#c9a84c] italic"
                style="font-family: 'Playfair Display', 'Georgia', serif; font-size: clamp(1.1rem, 4vw, 1.5rem); font-weight: 400;"
            >
                años
            </span>
        </div>

        <!-- FECHA -->
        <div class="flex flex-col items-center gap-1" id="fecha-xv">
            <!-- Día - número - mes -->
            <div
                class="flex items-center gap-2 sm:gap-3"
                style="font-family: 'Montserrat', 'Arial', sans-serif;"
            >
                <span
                    class="text-[10px] sm:text-xs tracking-[0.25em] font-semibold text-gray-700 uppercase"
                >
                    MARTES
                </span>
                <span class="text-[#c9a84c] text-sm font-light">|</span>
                <span
                    class="text-2xl sm:text-3xl font-light text-gray-800"
                    style="font-family: 'Playfair Display', serif;"
                >
                    30
                </span>
                <span class="text-[#c9a84c] text-sm font-light">|</span>
                <span
                    class="text-[10px] sm:text-xs tracking-[0.25em] font-semibold text-gray-700 uppercase"
                >
                    DICIEMBRE
                </span>
            </div>
            <!-- Año -->
            <p
                class="text-[10px] sm:text-xs tracking-[0.4em] text-gray-600 font-medium mt-1"
                style="font-family: 'Montserrat', sans-serif;"
            >
                2 0 2 5
            </p>
        </div>
    </div>

    <!-- Destellos / sparkles decorativos -->
    <div class="absolute inset-0 z-10 pointer-events-none" id="sparkles">
        <!-- Sparkle top right area -->
        <svg
            class="absolute top-[15%] right-[18%] w-4 h-4 text-pink-300 opacity-70"
            viewBox="0 0 20 20"
            fill="currentColor"
        >
            <path
                d="M10 0 L11.5 8.5 L20 10 L11.5 11.5 L10 20 L8.5 11.5 L0 10 L8.5 8.5 Z"
            ></path>
        </svg>
        <svg
            class="absolute top-[28%] right-[12%] w-3 h-3 text-pink-200 opacity-60"
            viewBox="0 0 20 20"
            fill="currentColor"
        >
            <path
                d="M10 0 L11.5 8.5 L20 10 L11.5 11.5 L10 20 L8.5 11.5 L0 10 L8.5 8.5 Z"
            ></path>
        </svg>
        <svg
            class="absolute bottom-[25%] right-[20%] w-3 h-3 text-pink-300 opacity-50"
            viewBox="0 0 20 20"
            fill="currentColor"
        >
            <path
                d="M10 0 L11.5 8.5 L20 10 L11.5 11.5 L10 20 L8.5 11.5 L0 10 L8.5 8.5 Z"
            ></path>
        </svg>
        <svg
            class="absolute bottom-[35%] left-[15%] w-2 h-2 text-pink-400 opacity-40"
            viewBox="0 0 20 20"
            fill="currentColor"
        >
            <path
                d="M10 0 L11.5 8.5 L20 10 L11.5 11.5 L10 20 L8.5 11.5 L0 10 L8.5 8.5 Z"
            ></path>
        </svg>
        <svg
            class="absolute top-[45%] left-[10%] w-3 h-3 text-pink-200 opacity-50"
            viewBox="0 0 20 20"
            fill="currentColor"
        >
            <path
                d="M10 0 L11.5 8.5 L20 10 L11.5 11.5 L10 20 L8.5 11.5 L0 10 L8.5 8.5 Z"
            ></path>
        </svg>
    </div>
</section>

<!-- Google Fonts -->
<link
    href="https://fonts.googleapis.com/css2?family=Great+Vibes&family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Montserrat:wght@400;500;600&display=swap"
    rel="stylesheet"
/>

<script>
    import { gsap } from "gsap";

    document.addEventListener("DOMContentLoaded", () => {
        // Estado inicial
        gsap.set("#deco-esfera", { opacity: 0, x: -60, y: -40 });
        gsap.set("#deco-globo", { opacity: 0, x: 60, y: -40 });
        gsap.set("#deco-fresa", { opacity: 0, x: -60, y: 40 });
        gsap.set("#deco-copa", { opacity: 0, x: 60, y: 40 });
        gsap.set("#marco", { opacity: 0, scale: 0.92 });
        gsap.set("#nombre-xv", { opacity: 0, y: 30, filter: "blur(8px)" });
        gsap.set("#subtitulo-xv", { opacity: 0, y: 20 });
        gsap.set("#fecha-xv", { opacity: 0, y: 20 });
        gsap.set("#sparkles", { opacity: 0 });

        const tl = gsap.timeline({ defaults: { ease: "power3.out" } });

        // Marco aparece primero
        tl.to("#marco", { opacity: 1, scale: 1, duration: 1.2 }, 0)

            // Decorativos entran desde esquinas
            .to(
                "#deco-esfera",
                {
                    opacity: 1,
                    x: 0,
                    y: 0,
                    duration: 1.1,
                    ease: "back.out(1.2)",
                },
                0.1,
            )
            .to(
                "#deco-globo",
                {
                    opacity: 1,
                    x: 0,
                    y: 0,
                    duration: 1.1,
                    ease: "back.out(1.2)",
                },
                0.15,
            )
            .to(
                "#deco-fresa",
                {
                    opacity: 1,
                    x: 0,
                    y: 0,
                    duration: 1.1,
                    ease: "back.out(1.2)",
                },
                0.2,
            )
            .to(
                "#deco-copa",
                {
                    opacity: 1,
                    x: 0,
                    y: 0,
                    duration: 1.1,
                    ease: "back.out(1.2)",
                },
                0.25,
            )

            // Nombre con efecto desenfoque
            .to(
                "#nombre-xv",
                {
                    opacity: 1,
                    y: 0,
                    filter: "blur(0px)",
                    duration: 1.4,
                    ease: "power2.out",
                },
                0.4,
            )

            // Subtítulo mis 15 años
            .to("#subtitulo-xv", { opacity: 1, y: 0, duration: 1 }, 0.7)

            // Fecha
            .to("#fecha-xv", { opacity: 1, y: 0, duration: 0.9 }, 0.9)

            // Sparkles al final
            .to("#sparkles", { opacity: 1, duration: 0.8 }, 1.0);

        // Animación flotante suave para los decorativos
        gsap.to("#deco-esfera", {
            y: -8,
            duration: 3,
            repeat: -1,
            yoyo: true,
            ease: "sine.inOut",
            delay: 1.5,
        });
        gsap.to("#deco-globo", {
            y: -6,
            duration: 3.5,
            repeat: -1,
            yoyo: true,
            ease: "sine.inOut",
            delay: 1.8,
        });
        gsap.to("#deco-copa", {
            y: -5,
            duration: 2.8,
            repeat: -1,
            yoyo: true,
            ease: "sine.inOut",
            delay: 2,
        });

        // Sparkles parpadeantes
        gsap.to("#sparkles svg", {
            opacity: 0.2,
            duration: 1.5,
            repeat: -1,
            yoyo: true,
            ease: "sine.inOut",
            stagger: 0.3,
            delay: 1.5,
        });
    });
</script>
