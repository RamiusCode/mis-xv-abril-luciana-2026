---
// HeroXV.astro - Sección principal Mis XV Años
// Solo animación de entrada simultánea, sin animaciones idle/loop
---

<section
    class="relative w-full overflow-hidden h-auto flex flex-col items-center justify-center py-20"
    id="hero-xv"
>
    <!-- ====== DECORATIVOS ESQUINAS ====== -->

    <!-- Esfera - esquina superior izquierda -->
    <div
        class="absolute top-10 left-0 z-20 w-28 sm:w-[36%] md:w-[30%]"
        id="deco-esfera"
    >
        <img
            src="/imagenes/esfera.png"
            alt="Esfera decorativa"
            class="w-full h-auto object-contain"
        />
    </div>

    <!-- Globo perrito - esquina superior derecha -->
    <div
        class="absolute top-50 right-0 z-20 w-14 sm:w-[18%] md:w-[15%]"
        id="deco-globo"
    >
        <img
            src="/imagenes/globoperrito.png"
            alt="Globo perrito decorativo"
            class="w-full h-auto object-contain"
        />
    </div>

    <!-- Fresa / cerezas - esquina inferior izquierda -->
    <div
        class="absolute bottom-50 left-0 z-20 w-16 sm:w-[22%] md:w-[18%]"
        id="deco-fresa"
    >
        <img
            src="/imagenes/fresa.png"
            alt="Fresa decorativa"
            class="w-full h-auto object-contain"
        />
    </div>

    <!-- Copa - esquina inferior derecha -->
    <div
        class="absolute bottom-7 right-0 z-20 w-18 sm:w-[18%] md:w-[15%]"
        id="deco-copa"
    >
        <img
            src="/imagenes/copa.png"
            alt="Copa decorativa"
            class="w-full h-auto object-contain"
        />
    </div>

    <!-- ====== SPARKLES DECORATIVOS ====== -->
    <div class="absolute inset-0 z-10 pointer-events-none" id="sparkles">
        <svg
            class="absolute top-[18%] right-[16%] w-3 h-3 text-pink-300 opacity-70"
            viewBox="0 0 20 20"
            fill="currentColor"
        >
            <path
                d="M10 0 L11.5 8.5 L20 10 L11.5 11.5 L10 20 L8.5 11.5 L0 10 L8.5 8.5 Z"
            ></path>
        </svg>
        <svg
            class="absolute top-[32%] right-[10%] w-2 h-2 text-pink-200 opacity-60"
            viewBox="0 0 20 20"
            fill="currentColor"
        >
            <path
                d="M10 0 L11.5 8.5 L20 10 L11.5 11.5 L10 20 L8.5 11.5 L0 10 L8.5 8.5 Z"
            ></path>
        </svg>
        <svg
            class="absolute top-[22%] left-[12%] w-2 h-2 text-pink-300 opacity-50"
            viewBox="0 0 20 20"
            fill="currentColor"
        >
            <path
                d="M10 0 L11.5 8.5 L20 10 L11.5 11.5 L10 20 L8.5 11.5 L0 10 L8.5 8.5 Z"
            ></path>
        </svg>
        <svg
            class="absolute bottom-[30%] right-[14%] w-3 h-3 text-pink-200 opacity-50"
            viewBox="0 0 20 20"
            fill="currentColor"
        >
            <path
                d="M10 0 L11.5 8.5 L20 10 L11.5 11.5 L10 20 L8.5 11.5 L0 10 L8.5 8.5 Z"
            ></path>
        </svg>
        <svg
            class="absolute bottom-[40%] left-[8%] w-2 h-2 text-pink-300 opacity-40"
            viewBox="0 0 20 20"
            fill="currentColor"
        >
            <path
                d="M10 0 L11.5 8.5 L20 10 L11.5 11.5 L10 20 L8.5 11.5 L0 10 L8.5 8.5 Z"
            ></path>
        </svg>
    </div>

    <!-- ====== BLOQUE CENTRAL: MARCO + CONTENIDO ====== -->
    <!-- Marco subido un poco más: -mt-8 en móvil, -mt-12 en sm+ -->
    <div
        class="relative z-0 w-[78%] sm:w-[68%] md:w-[56%] lg:w-[48%] max-w-xs sm:max-w-sm mx-auto -mt-8 sm:-mt-12"
        id="bloque-central"
    >
        <div class="relative pt-20 z-[-1]" id="marco-wrap">
            <!-- Marco como imagen base del bloque -->
            <img
                src="/imagenes/marco.png"
                alt="Marco decorativo"
                class="w-full h-auto block"
                id="marco"
            />

            <!-- CONTENIDO SUPERPUESTO AL MARCO -->
            <div
                class="absolute inset-0 flex flex-col items-center justify-center text-center px-5 pt-28 pb-8"
                id="contenido-central"
            >
                <!-- NOMBRE -->
                <h1
                    class="font-great-vibes text-[65px] sm:text-[64px] leading-tight text-[#c4607a] mb-2"
                    id="nombre-xv"
                >
                    Abril<br />Luciana
                </h1>

                <!-- LOGO debajo del 15 -->
                <div class="mb-3 pt-4 pb-4 w-28 h-auto" id="logo-xv">
                    <img src="/imagenes/logo.png" alt="Logo" class="mx-auto" />
                </div>

                <!-- FECHA -->
                <div class="flex flex-col items-center gap-0.5" id="fecha-xv">
                    <div class="flex items-center gap-2">
                        <span
                            class="font-crimson text-2xl sm:text-xs font-semibold text-[#eb8fa3] uppercase"
                        >
                            SÁBADO
                        </span>
                        <span class="text-[#c9a84c] text-sm">|</span>
                        <span
                            class="font-crimson text-2xl sm:text-2xl font-light text-[#eb8fa3]"
                        >
                            11
                        </span>
                        <span class="text-[#c9a84c] text-sm">|</span>
                        <span
                            class="font-crimson text-2xl sm:text-xs font-semibold text-[#eb8fa3] uppercase"
                        >
                            ABRIL
                        </span>
                    </div>
                    <p class="font-crimson text-2xl sm:text-xs text-[#eb8fa3]">
                        2 0 2 6
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    import { gsap } from "gsap";

    document.addEventListener("DOMContentLoaded", () => {
        // Estado inicial: todo invisible
        gsap.set("#deco-esfera", { opacity: 0, x: -50, y: -30 });
        gsap.set("#deco-globo", { opacity: 0, x: 50, y: -30 });
        gsap.set("#deco-fresa", { opacity: 0, x: -50, y: 30 });
        gsap.set("#deco-copa", { opacity: 0, x: 50, y: 30 });
        gsap.set("#marco", { opacity: 0, scale: 0.94 });
        gsap.set("#texto-invitados", { opacity: 0, y: -10 });
        gsap.set("#texto-bonita", { opacity: 0, y: -10 });
        gsap.set("#nombre-xv", { opacity: 0, y: 20, filter: "blur(8px)" });
        gsap.set("#subtitulo-xv", { opacity: 0, y: 15 });
        gsap.set("#flores-xv", { opacity: 0, scale: 0.7 });
        gsap.set("#fecha-xv", { opacity: 0, y: 15 });
        gsap.set("#sparkles", { opacity: 0 });

        // ====== SOLO ANIMACIÓN DE ENTRADA: todo al mismo tiempo ======
        const DURATION = 1.1;
        const EASE = "power3.out";

        gsap.to("#marco", {
            opacity: 1,
            scale: 1,
            duration: DURATION,
            ease: EASE,
        });
        gsap.to("#deco-esfera", {
            opacity: 1,
            x: 0,
            y: 0,
            duration: DURATION,
            ease: "back.out(1.2)",
        });
        gsap.to("#deco-globo", {
            opacity: 1,
            x: 0,
            y: 0,
            duration: DURATION,
            ease: "back.out(1.2)",
        });
        gsap.to("#deco-fresa", {
            opacity: 1,
            x: 0,
            y: 0,
            duration: DURATION,
            ease: "back.out(1.2)",
        });
        gsap.to("#deco-copa", {
            opacity: 1,
            x: 0,
            y: 0,
            duration: DURATION,
            ease: "back.out(1.2)",
        });
        gsap.to("#texto-invitados", {
            opacity: 1,
            y: 0,
            duration: DURATION,
            ease: EASE,
        });
        gsap.to("#texto-bonita", {
            opacity: 1,
            y: 0,
            duration: DURATION,
            ease: EASE,
        });
        gsap.to("#nombre-xv", {
            opacity: 1,
            y: 0,
            filter: "blur(0px)",
            duration: DURATION,
            ease: "power2.out",
        });
        gsap.to("#subtitulo-xv", {
            opacity: 1,
            y: 0,
            duration: DURATION,
            ease: EASE,
        });
        gsap.to("#flores-xv", {
            opacity: 1,
            scale: 1,
            duration: DURATION,
            ease: "back.out(1.6)",
        });
        gsap.to("#fecha-xv", {
            opacity: 1,
            y: 0,
            duration: DURATION,
            ease: EASE,
        });
        gsap.to("#sparkles", { opacity: 1, duration: DURATION, ease: EASE });
    });
</script>
