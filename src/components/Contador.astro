---
// ContadorNubeFinal.astro - Texto Extra Grande, Limpio y en Una Sola Línea
---

<section
  class="py-16 md:py-24 relative overflow-hidden bg-transparent"
  id="seccion-contador"
>
  <div class="text-center mb-6 md:mb-16" id="titulo-contador">
    <h2 class="font-great-vibes text-5xl md:text-7xl text-[#eb8fa3] mb-2">
      ¡Tan solo faltan!
    </h2>
  </div>

  <div
    class="relative w-full max-w-7xl mx-auto px-2 h-48 md:h-80 flex items-center justify-center"
  >
    <div
      class="absolute inset-0 z-0 flex items-center justify-center pointer-events-none"
    >
      <img
        src="/imagenes/nube.png"
        alt="Fondo nube"
        class="w-full h-full object-contain opacity-100 scale-150 md:scale-125"
      />
    </div>

    <div
      class="relative z-10 flex flex-nowrap items-center justify-center gap-1 sm:gap-6 md:gap-10 text-center w-full"
      id="numeros-container"
    >
      <div class="flex flex-col items-center">
        <span
          class="font-charm text-[13vw] sm:text-7xl md:text-9xl font-bold text-white leading-none"
          id="dias"
        >
          00
        </span>
        <span
          class="text-[2.8vw] sm:text-sm md:text-base text-white uppercase font-bold tracking-widest mt-1"
        >
          Días
        </span>
      </div>

      <div
        class="text-white text-[10vw] sm:text-5xl md:text-7xl font-bold self-center mb-6 md:mb-10"
      >
        :
      </div>

      <div class="flex flex-col items-center">
        <span
          class="font-charm text-[13vw] sm:text-7xl md:text-9xl font-bold text-white leading-none"
          id="horas"
        >
          00
        </span>
        <span
          class="text-[2.8vw] sm:text-sm md:text-base text-white uppercase font-bold tracking-widest mt-1"
        >
          Horas
        </span>
      </div>

      <div
        class="text-white text-[10vw] sm:text-5xl md:text-7xl font-bold self-center mb-6 md:mb-10"
      >
        :
      </div>

      <div class="flex flex-col items-center">
        <span
          class="font-charm text-[13vw] sm:text-7xl md:text-9xl font-bold text-white leading-none"
          id="minutos"
        >
          00
        </span>
        <span
          class="text-[2.8vw] sm:text-sm md:text-base text-white uppercase font-bold tracking-widest mt-1"
        >
          Minutos
        </span>
      </div>

      <div
        class="text-white text-[10vw] sm:text-5xl md:text-7xl font-bold self-center mb-6 md:mb-10"
      >
        :
      </div>

      <div class="flex flex-col items-center">
        <span
          class="font-charm text-[13vw] sm:text-7xl md:text-9xl font-bold text-white leading-none"
          id="segundos"
        >
          00
        </span>
        <span
          class="text-[2.8vw] sm:text-sm md:text-base text-white uppercase font-bold tracking-widest mt-1"
        >
          Segundos
        </span>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  // FECHA CONFIGURADA: 11 de Abril de 2026
  const fechaEvento = new Date("2026-04-11T20:00:00").getTime();

  function actualizarContador() {
    const ahora = new Date().getTime();
    const diferencia = fechaEvento - ahora;

    if (diferencia > 0) {
      const d = Math.floor(diferencia / (1000 * 60 * 60 * 24));
      const h = Math.floor(
        (diferencia % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60),
      );
      const m = Math.floor((diferencia % (1000 * 60 * 60)) / (1000 * 60));
      const s = Math.floor((diferencia % (1000 * 60)) / 1000);

      const diasEl = document.getElementById("dias");
      const horasEl = document.getElementById("horas");
      const minutosEl = document.getElementById("minutos");
      const segundosEl = document.getElementById("segundos");

      if (diasEl) diasEl.textContent = String(d).padStart(2, "0");
      if (horasEl) horasEl.textContent = String(h).padStart(2, "0");
      if (minutosEl) minutosEl.textContent = String(m).padStart(2, "0");
      if (segundosEl) segundosEl.textContent = String(s).padStart(2, "0");
    }
  }

  setInterval(actualizarContador, 1000);
  actualizarContador();

  document.addEventListener("DOMContentLoaded", () => {
    gsap.from("#numeros-container", {
      scrollTrigger: "#numeros-container",
      opacity: 0,
      y: 15,
      duration: 1.2,
      ease: "power2.out",
    });
  });
</script>

<style>
  /* Mantiene todo en una línea horizontal */
  #numeros-container {
    white-space: nowrap;
  }

  /* Evita saltos visuales en los números */
  #dias,
  #horas,
  #minutos,
  #segundos {
    font-variant-numeric: tabular-nums;
  }
</style>
