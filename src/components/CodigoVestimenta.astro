---
// CodigoVestimenta.astro - Sección código de vestimenta Mis XV Años
---

<section
  class="relative w-full overflow-hidden flex flex-col items-center justify-center bg-transparent py-10 px-4"
  id="codigo-xv"
>
  <!-- ====== DECORATIVOS LATERALES ====== -->

  <!-- Moño - lado izquierdo -->
  <!-- <div
    class="absolute left-0 top-[50%] z-20 w-[22%] sm:w-[18%] md:w-[14%]"
    id="deco-mono-cod"
  >
    <img
      src="/imagenes/mono.png"
      alt="Moño decorativo"
      class="w-full h-auto object-contain"
    />
  </div> -->

  <!-- Corazón - lado derecho -->
  <!-- <div
    class="absolute right-0 top-[10%] z-20 w-[22%] sm:w-[18%] md:w-[14%]"
    id="deco-corazon-cod"
  >
    <img
      src="/imagenes/corazon.png"
      alt="Corazón decorativo"
      class="w-full h-auto object-contain"
    />
  </div> -->

  <!-- ====== SPARKLES DECORATIVOS ====== -->
  <div class="absolute inset-0 z-10 pointer-events-none" id="sparkles-cod">
    <!-- estrella grande top-left -->
    <svg
      class="absolute top-[8%] left-[14%] w-4 h-4 text-pink-300 opacity-55"
      viewBox="0 0 20 20"
      fill="currentColor"
    >
      <path
        d="M10 0 L11.5 8.5 L20 10 L11.5 11.5 L10 20 L8.5 11.5 L0 10 L8.5 8.5 Z"
      ></path>
    </svg>
    <svg
      class="absolute top-[6%] left-[22%] w-2 h-2 text-pink-200 opacity-45"
      viewBox="0 0 20 20"
      fill="currentColor"
    >
      <path
        d="M10 0 L11.5 8.5 L20 10 L11.5 11.5 L10 20 L8.5 11.5 L0 10 L8.5 8.5 Z"
      ></path>
    </svg>
    <!-- estrella top-right -->
    <svg
      class="absolute top-[18%] right-[10%] w-5 h-5 text-pink-300 opacity-50"
      viewBox="0 0 20 20"
      fill="currentColor"
    >
      <path
        d="M10 0 L11.5 8.5 L20 10 L11.5 11.5 L10 20 L8.5 11.5 L0 10 L8.5 8.5 Z"
      ></path>
    </svg>
    <svg
      class="absolute top-[24%] right-[18%] w-2 h-2 text-pink-200 opacity-40"
      viewBox="0 0 20 20"
      fill="currentColor"
    >
      <path
        d="M10 0 L11.5 8.5 L20 10 L11.5 11.5 L10 20 L8.5 11.5 L0 10 L8.5 8.5 Z"
      ></path>
    </svg>
    <!-- estrella mid-left -->
    <svg
      class="absolute top-[42%] left-[8%] w-3 h-3 text-pink-300 opacity-40"
      viewBox="0 0 20 20"
      fill="currentColor"
    >
      <path
        d="M10 0 L11.5 8.5 L20 10 L11.5 11.5 L10 20 L8.5 11.5 L0 10 L8.5 8.5 Z"
      ></path>
    </svg>
    <!-- estrellas bottom -->
    <svg
      class="absolute bottom-[22%] left-[12%] w-4 h-4 text-pink-300 opacity-50"
      viewBox="0 0 20 20"
      fill="currentColor"
    >
      <path
        d="M10 0 L11.5 8.5 L20 10 L11.5 11.5 L10 20 L8.5 11.5 L0 10 L8.5 8.5 Z"
      ></path>
    </svg>
    <svg
      class="absolute bottom-[18%] left-[20%] w-2 h-2 text-pink-200 opacity-35"
      viewBox="0 0 20 20"
      fill="currentColor"
    >
      <path
        d="M10 0 L11.5 8.5 L20 10 L11.5 11.5 L10 20 L8.5 11.5 L0 10 L8.5 8.5 Z"
      ></path>
    </svg>
    <svg
      class="absolute bottom-[30%] right-[12%] w-3 h-3 text-pink-200 opacity-40"
      viewBox="0 0 20 20"
      fill="currentColor"
    >
      <path
        d="M10 0 L11.5 8.5 L20 10 L11.5 11.5 L10 20 L8.5 11.5 L0 10 L8.5 8.5 Z"
      ></path>
    </svg>
  </div>

  <!-- ====== CONTENIDO CENTRAL ====== -->
  <div
    class="relative z-30 w-full max-w-[280px] sm:max-w-xs flex flex-col items-center gap-6"
    id="contenido-cod"
  >
    <!-- TÍTULO CÓDIGO DE VESTIMENTA -->
    <div class="flex flex-col items-center gap-1 text-center" id="titulo-cod">
      <p class="font-great-vibes text-4xl text-[#D4AF37] leading-tight">
        Código de vestimenta
      </p>
      <p class="font-charm text-xl text-[#eb8fa3] font-bold">Formal</p>
    </div>

    <!-- IMAGEN PAREJA -->
    <div class="flex items-center justify-center" id="img-cod">
      <img
        src="/imagenes/vestimenta.png"
        alt="Código de vestimenta formal"
        class="w-28 h-auto object-contain icono-rosado"
      />
    </div>

    <!-- SEPARADOR -->
    <div
      class="w-[65%] h-px bg-gradient-to-r from-transparent via-pink-300 to-transparent opacity-55"
    >
    </div>

    <!-- COLORES RESERVADOS -->
    <div class="flex flex-col items-center gap-3 text-center" id="colores-cod">
      <p class="font-great-vibes text-4xl text-[#D4AF37]">
        Colores reservados<br />para la Quinceañera
      </p>

      <p
        class="font-charm text-xl tracking-[0.18em] text-[#eb8fa3] font-medium"
      >
        Rosa Pastel y Dorado
      </p>

      <!-- CÍRCULOS DE COLORES ELEGANTES -->
      <div
        class="flex items-center justify-center gap-5 my-1"
        id="circulos-cod"
      >
        <!-- Círculo Rosa Pastel -->
        <div
          class="relative flex items-center justify-center"
          id="circulo-rosa"
        >
          <!-- Anillo exterior dorado fino -->
          <div
            class="absolute w-[54px] h-[54px] rounded-full"
            style="border: 1.5px solid rgba(201,168,76,0.55);"
          >
          </div>
          <!-- Círculo relleno rosa pastel -->
          <div
            class="w-11 h-11 rounded-full"
            style="background: linear-gradient(135deg, #f5c6d4 0%, #e8a0b0 60%, #d98098 100%); box-shadow: 0 3px 12px rgba(196,96,122,0.25), inset 0 1px 3px rgba(255,255,255,0.5);"
          >
          </div>
        </div>

        <!-- Círculo Dorado -->
        <div
          class="relative flex items-center justify-center"
          id="circulo-dorado"
        >
          <!-- Anillo exterior rosado fino -->
          <div
            class="absolute w-[54px] h-[54px] rounded-full"
            style="border: 1.5px solid rgba(196,96,122,0.45);"
          >
          </div>
          <!-- Círculo relleno dorado -->
          <div
            class="w-11 h-11 rounded-full"
            style="background: linear-gradient(135deg, #f0d875 0%, #c9a84c 50%, #a8892e 100%); box-shadow: 0 3px 12px rgba(201,168,76,0.35), inset 0 1px 3px rgba(255,255,255,0.4);"
          >
          </div>
        </div>
      </div>

      <!-- FAVOR DE EVITARLOS -->
      <p class="font-charm text-xl text-[#eb8fa3] mt-1">Favor de evitarlos.</p>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";

  document.addEventListener("DOMContentLoaded", () => {
    gsap.set("#deco-mono-cod", { opacity: 0, x: -40 });
    gsap.set("#deco-corazon-cod", { opacity: 0, x: 40 });
    gsap.set("#titulo-cod", { opacity: 0, y: 18 });
    gsap.set("#img-cod", { opacity: 0, scale: 0.88 });
    gsap.set("#colores-cod", { opacity: 0, y: 18 });
    gsap.set("#circulos-cod", { opacity: 0, scale: 0.75 });
    gsap.set("#sparkles-cod", { opacity: 0 });

    const DURATION = 1.1;
    const EASE = "power3.out";

    gsap.to("#deco-mono-cod", {
      opacity: 1,
      x: 0,
      duration: DURATION,
      ease: "back.out(1.2)",
    });
    gsap.to("#deco-corazon-cod", {
      opacity: 1,
      x: 0,
      duration: DURATION,
      ease: "back.out(1.2)",
    });
    gsap.to("#titulo-cod", {
      opacity: 1,
      y: 0,
      duration: DURATION,
      ease: EASE,
    });
    gsap.to("#img-cod", {
      opacity: 1,
      scale: 1,
      duration: DURATION,
      ease: "back.out(1.3)",
    });
    gsap.to("#colores-cod", {
      opacity: 1,
      y: 0,
      duration: DURATION,
      ease: EASE,
    });
    gsap.to("#circulos-cod", {
      opacity: 1,
      scale: 1,
      duration: DURATION,
      ease: "back.out(1.6)",
    });
    gsap.to("#sparkles-cod", { opacity: 1, duration: DURATION, ease: EASE });
  });
</script>

<style>
  /* Filtro rosado para #eb8fa3 */
  .icono-rosado {
    filter: brightness(0) saturate(100%) invert(73%) sepia(29%) saturate(894%)
      hue-rotate(300deg) brightness(96%) contrast(92%);
    transition:
      filter 0.3s ease,
      transform 0.3s ease;
  }
</style>
